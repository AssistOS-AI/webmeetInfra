{
    "container": "docker.io/livekit/livekit-server:${WEBMEET_LIVEKIT_VERSION}",
    "about": "LiveKit SFU for WebMeet rooms.",
    "enable": [
        "webmeetInfra/webmeetRedis"
    ],
    "start": "--config /working-data/generated/livekit.yaml",
    "volumes": {
        ".ploinky/agents/webmeetLivekitServer/livekit.yaml": "/working-data/generated/livekit.yaml"
    },
    "volumeOptions": {
        "/working-data/generated/livekit.yaml": {
            "generated": true,
            "required": true
        }
    },
    "profiles": {
        "default": {
            "preinstall": "scripts/hooks/preinstall.sh",
            "network": {
                "name": "webmeet",
                "aliases": ["webmeetLivekitServer"]
            },
            "env": [
                {
                    "name": "WEBMEET_LIVEKIT_API_KEY",
                    "required": false,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-key",
                    "deriveBytes": 16
                },
                {
                    "name": "WEBMEET_LIVEKIT_API_SECRET",
                    "required": false,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-secret"
                },
                {
                    "name": "WEBMEET_LIVEKIT_USE_EXTERNAL_IP",
                    "required": false,
                    "default": "false"
                },
                {
                    "name": "WEBMEET_LIVEKIT_LOG_LEVEL",
                    "required": false,
                    "default": "info"
                },
                {
                    "name": "WEBMEET_LIVEKIT_FORCE_TCP",
                    "required": false,
                    "default": "false"
                },
                {
                    "name": "WEBMEET_LIVEKIT_VERSION",
                    "required": false,
                    "default": "v1.11.0"
                },
                {
                    "name": "WEBMEET_LIVEKIT_REDIS_ADDRESS",
                    "required": false,
                    "default": "webmeetRedis:6379"
                }
            ],
            "ports": ["7880:7880", "7881:7881", "7882-7892:7882-7892/udp"]
        },
        "dev": {
            "preinstall": "scripts/hooks/preinstall.sh",
            "network": {
                "name": "webmeet",
                "aliases": ["webmeetLivekitServer"]
            },
            "env": [
                {
                    "name": "WEBMEET_LIVEKIT_API_KEY",
                    "required": false,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-key",
                    "deriveBytes": 16
                },
                {
                    "name": "WEBMEET_LIVEKIT_API_SECRET",
                    "required": false,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-secret"
                },
                {
                    "name": "WEBMEET_LIVEKIT_USE_EXTERNAL_IP",
                    "required": false,
                    "default": "false"
                },
                {
                    "name": "WEBMEET_LIVEKIT_LOG_LEVEL",
                    "required": false,
                    "default": "info"
                },
                {
                    "name": "WEBMEET_LIVEKIT_FORCE_TCP",
                    "required": false,
                    "default": "false"
                },
                {
                    "name": "WEBMEET_LIVEKIT_VERSION",
                    "required": false,
                    "default": "v1.11.0"
                },
                {
                    "name": "WEBMEET_LIVEKIT_REDIS_ADDRESS",
                    "required": false,
                    "default": "webmeetRedis:6379"
                }
            ],
            "ports": ["17880:17880", "17881:17881", "17882-17892:17882-17892/udp"]
        },
        "prod": {
            "preinstall": "scripts/hooks/preinstall.sh",
            "network": {
                "mode": "host"
            },
            "env": [
                {
                    "name": "WEBMEET_LIVEKIT_API_KEY",
                    "required": true,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-key",
                    "deriveBytes": 16
                },
                {
                    "name": "WEBMEET_LIVEKIT_API_SECRET",
                    "required": true,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-secret"
                },
                {
                    "name": "WEBMEET_LIVEKIT_USE_EXTERNAL_IP",
                    "required": false,
                    "default": "true"
                },
                {
                    "name": "WEBMEET_LIVEKIT_NODE_IP",
                    "required": false
                },
                {
                    "name": "WEBMEET_LIVEKIT_LOG_LEVEL",
                    "required": false,
                    "default": "info"
                },
                {
                    "name": "WEBMEET_LIVEKIT_FORCE_TCP",
                    "required": false,
                    "default": "false"
                },
                {
                    "name": "WEBMEET_LIVEKIT_VERSION",
                    "required": false,
                    "default": "v1.11.0"
                }
            ],
            "ports": ["0.0.0.0:7880:7880", "0.0.0.0:7881:7881", "0.0.0.0:7882-7892:7882-7892/udp"]
        }
    }
}
