{
    "container": "docker.io/livekit/livekit-server:latest",
    "about": "LiveKit SFU for WebMeet rooms.",
    "network": {
        "mode": "host"
    },
    "enable": [
        "webmeetInfra/webmeetRedis"
    ],
    "start": "--config /code/livekit.yaml",
    "volumes": {
        ".ploinky/agents/webmeetLivekitServer/livekit.yaml": "/code/livekit.yaml"
    },
    "volumeOptions": {
        "/code/livekit.yaml": {
            "generated": true,
            "required": true
        }
    },
    "profiles": {
        "default": {
            "preinstall": "scripts/hooks/preinstall.sh",
            "env": [
                {
                    "name": "WEBMEET_LIVEKIT_API_KEY",
                    "required": false,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-key",
                    "deriveBytes": 16
                },
                {
                    "name": "WEBMEET_LIVEKIT_API_SECRET",
                    "required": false,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-secret"
                },
                {
                    "name": "WEBMEET_LIVEKIT_USE_EXTERNAL_IP",
                    "required": false,
                    "default": "false"
                },
                {
                    "name": "WEBMEET_LIVEKIT_LOG_LEVEL",
                    "required": false,
                    "default": "info"
                },
                {
                    "name": "WEBMEET_LIVEKIT_FORCE_TCP",
                    "required": false,
                    "default": "false"
                }
            ]
        },
        "dev": {
            "preinstall": "scripts/hooks/preinstall.sh",
            "env": [
                {
                    "name": "WEBMEET_LIVEKIT_API_KEY",
                    "required": false,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-key",
                    "deriveBytes": 16
                },
                {
                    "name": "WEBMEET_LIVEKIT_API_SECRET",
                    "required": false,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-secret"
                },
                {
                    "name": "WEBMEET_LIVEKIT_USE_EXTERNAL_IP",
                    "required": false,
                    "default": "false"
                },
                {
                    "name": "WEBMEET_LIVEKIT_LOG_LEVEL",
                    "required": false,
                    "default": "info"
                },
                {
                    "name": "WEBMEET_LIVEKIT_FORCE_TCP",
                    "required": false,
                    "default": "false"
                }
            ]
        },
        "prod": {
            "preinstall": "scripts/hooks/preinstall.sh",
            "env": [
                {
                    "name": "WEBMEET_LIVEKIT_API_KEY",
                    "required": true,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-key",
                    "deriveBytes": 16
                },
                {
                    "name": "WEBMEET_LIVEKIT_API_SECRET",
                    "required": true,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-secret"
                },
                {
                    "name": "WEBMEET_LIVEKIT_USE_EXTERNAL_IP",
                    "required": false,
                    "default": "true"
                },
                {
                    "name": "WEBMEET_LIVEKIT_NODE_IP",
                    "required": false
                },
                {
                    "name": "WEBMEET_LIVEKIT_LOG_LEVEL",
                    "required": false,
                    "default": "info"
                },
                {
                    "name": "WEBMEET_LIVEKIT_FORCE_TCP",
                    "required": false,
                    "default": "false"
                }
            ]
        }
    }
}
