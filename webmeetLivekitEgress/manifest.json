{
    "container": "docker.io/livekit/egress:latest",
    "about": "LiveKit egress worker for WebMeet recordings.",
    "network": {
        "name": "webmeet",
        "aliases": ["webmeetLivekitEgress"]
    },
    "enable": [
        "webmeetInfra/webmeetLivekitServer",
        "webmeetInfra/webmeetRedis"
    ],
    "start": "true",
    "capabilities": ["SYS_ADMIN"],
    "volumes": {
        "webmeet/recordings": "/recordings",
        ".ploinky/agents/webmeetLivekitEgress/egress.yaml": "/code/egress.yaml"
    },
    "volumeOptions": {
        "/code/egress.yaml": {
            "generated": true,
            "required": true
        }
    },
    "profiles": {
        "default": {
            "preinstall": "scripts/hooks/preinstall.sh",
            "env": [
                {
                    "name": "EGRESS_CONFIG_FILE",
                    "required": false,
                    "default": "/code/egress.yaml"
                },
                {
                    "name": "WEBMEET_LIVEKIT_API_KEY",
                    "required": false,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-key",
                    "deriveBytes": 16
                },
                {
                    "name": "WEBMEET_LIVEKIT_API_SECRET",
                    "required": false,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-secret"
                }
            ],
            "ports": ["7980:7980"]
        },
        "dev": {
            "preinstall": "scripts/hooks/preinstall.sh",
            "env": [
                {
                    "name": "EGRESS_CONFIG_FILE",
                    "required": false,
                    "default": "/code/egress.yaml"
                },
                {
                    "name": "WEBMEET_LIVEKIT_API_KEY",
                    "required": false,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-key",
                    "deriveBytes": 16
                },
                {
                    "name": "WEBMEET_LIVEKIT_API_SECRET",
                    "required": false,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-secret"
                }
            ],
            "ports": ["17980:7980"]
        },
        "prod": {
            "preinstall": "scripts/hooks/preinstall.sh",
            "env": [
                {
                    "name": "EGRESS_CONFIG_FILE",
                    "required": false,
                    "default": "/code/egress.yaml"
                },
                {
                    "name": "WEBMEET_LIVEKIT_API_KEY",
                    "required": true,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-key",
                    "deriveBytes": 16
                },
                {
                    "name": "WEBMEET_LIVEKIT_API_SECRET",
                    "required": true,
                    "derive": "derived-master",
                    "deriveRepoName": "webmeet",
                    "deriveAgentName": "shared-livekit",
                    "deriveName": "api-secret"
                }
            ],
            "ports": ["7980:7980"]
        }
    }
}
