{
    "container": "livekit/egress:latest",
    "about": "LiveKit egress worker for WebMeet recordings.",
    "network": {
        "name": "webmeet",
        "aliases": ["webmeetLivekitEgress"]
    },
    "start": "true",
    "capabilities": ["SYS_ADMIN"],
    "volumes": {
        "webmeet/recordings": "/recordings",
        ".ploinky/agents/webmeetLivekitEgress/egress.yaml": "/code/egress.yaml"
    },
    "volumeOptions": {
        "/code/egress.yaml": {
            "generated": true,
            "required": true
        }
    },
    "profiles": {
        "default": {
            "preinstall": "scripts/hooks/preinstall.sh",
            "env": {
                "EGRESS_CONFIG_FILE": "/code/egress.yaml",
                "WEBMEET_LIVEKIT_API_KEY": "devkey",
                "WEBMEET_LIVEKIT_API_SECRET": "devsecretdevsecretdevsecretdevsecret"
            },
            "ports": ["7980:7980"]
        },
        "dev": {
            "preinstall": "scripts/hooks/preinstall.sh",
            "env": {
                "EGRESS_CONFIG_FILE": "/code/egress.yaml",
                "WEBMEET_LIVEKIT_API_KEY": "devkey",
                "WEBMEET_LIVEKIT_API_SECRET": "devsecretdevsecretdevsecretdevsecret"
            },
            "ports": ["17980:7980"]
        },
        "prod": {
            "preinstall": "scripts/hooks/preinstall.sh",
            "env": {
                "EGRESS_CONFIG_FILE": "/code/egress.yaml"
            },
            "ports": ["7980:7980"]
        }
    }
}
