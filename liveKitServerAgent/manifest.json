{
  "container": "docker.io/assistos/livekit-server-agent@sha256:e8aee1f63763a3dcb427f47d3e0aab78b7932a8c1d6140fce43f7bde960b47f8",
  "about": "WebMeet LiveKit signaling, single-port UDP media, Redis, and Egress runtime.",
  "start": "sh /code/scripts/start-livekit-server-agent.sh",
  "health": {
    "readiness": {
      "script": "healthcheck.sh",
      "interval": 5,
      "timeout": 10,
      "failureThreshold": 60,
      "successThreshold": 1
    }
  },
  "network": {
    "mode": "host"
  },
  "containerSecurity": {
    "privileged": false
  },
  "volumes": {
    ".data/liveKitServerAgent/generated": "/working-data/generated",
    ".ploinky/data/webmeet/redis": "/data/redis",
    ".ploinky/data/webmeet/recordings": "/data/recordings"
  },
  "volumeOptions": {
    "/working-data/generated": {
      "generated": true,
      "required": true
    }
  },
  "httpServices": [
    {
      "slug": "livekit-signal",
      "port": 7880,
      "externalPrefix": "/public-services/livekit-signal/",
      "internalPrefix": "/",
      "access": "public"
    },
    {
      "slug": "livekit-api",
      "port": 7880,
      "externalPrefix": "/services/livekit-api/",
      "internalPrefix": "/twirp/livekit.RoomService/",
      "access": "authenticated"
    }
  ],
  "profiles": {
    "default": {
      "preinstall": "scripts/hooks/preinstall.sh",
      "env": [
        {
          "name": "LIVEKIT_API_KEY",
          "required": true,
          "sharedGeneratedSecret": true
        },
        {
          "name": "LIVEKIT_API_SECRET",
          "required": true,
          "sharedGeneratedSecret": true
        }
      ]
    },
    "dev": {
      "preinstall": "scripts/hooks/preinstall.sh",
      "env": [
        {
          "name": "LIVEKIT_API_KEY",
          "required": true,
          "sharedGeneratedSecret": true
        },
        {
          "name": "LIVEKIT_API_SECRET",
          "required": true,
          "sharedGeneratedSecret": true
        }
      ]
    },
    "prod": {
      "preinstall": "scripts/hooks/preinstall.sh",
      "env": [
        {
          "name": "LIVEKIT_API_KEY",
          "required": true,
          "sharedGeneratedSecret": true
        },
        {
          "name": "LIVEKIT_API_SECRET",
          "required": true,
          "sharedGeneratedSecret": true
        }
      ]
    }
  }
}
