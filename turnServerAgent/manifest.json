{
    "container": "docker.io/coturn/coturn@sha256:0c0e8fc0c263b85a134e9e4242b5e46e1f4c077c5029633511191c05b5c2c814",
    "about": "TURN relay for WebMeet media. Uses coturn's shared-secret REST/ephemeral auth (use-auth-secret), not static long-term credentials. The pinned digest corresponds to the upstream tag docker.io/coturn/coturn:4.14.0-r0-debian (manifest-list digest, verified against the Docker Hub registry v2 API); pinned by digest because the tag itself is mutable and not human-derivable from the digest alone.",
    "entrypoint": "/usr/bin/env",
    "start": "sh /code/scripts/start-turn-server-agent.sh",
    "health": {
        "readiness": {
            "script": "readiness.sh",
            "timeout": 10
        }
    },
    "containerSecurity": {
        "privileged": false
    },
    "network": {
        "mode": "bridge",
        "attachments": [
            {
                "name": "webmeet-turn",
                "primary": true
            }
        ]
    },
    "volumes": {
        ".ploinky/data/webmeetTls/turn": "/etc/turnserver/tls",
        ".ploinky/data/webmeetSecrets/turn": "/run/webmeet-turn-secret"
    },
    "volumeOptions": {
        "/etc/turnserver/tls": {
            "readOnly": true
        },
        "/run/webmeet-turn-secret": {
            "generated": true,
            "required": true,
            "readOnly": true,
            "chmod": 493
        }
    },
    "profiles": {
        "default": {
            "preinstall": "scripts/hooks/preinstall.sh",
            "openPorts": [
                "127.0.0.1:3478:3478/tcp",
                "127.0.0.1:3478:3478/udp",
                "127.0.0.1:20000-20127:20000-20127/udp"
            ],
            "env": [
                {
                    "name": "WEBMEET_TURN_AUTH_SECRET",
                    "required": false,
                    "sharedGeneratedSecret": true,
                    "runtime": false
                },
                {
                    "name": "WEBMEET_TURN_HOST",
                    "required": false,
                    "default": "127.0.0.1"
                },
                {
                    "name": "WEBMEET_TURN_USER_QUOTA",
                    "required": false,
                    "default": "4"
                },
                {
                    "name": "WEBMEET_TURN_TOTAL_QUOTA",
                    "required": false,
                    "default": "100"
                },
                {
                    "name": "WEBMEET_TURN_MAX_BPS",
                    "required": false,
                    "default": "2000000"
                },
                {
                    "name": "WEBMEET_TURN_BPS_CAPACITY",
                    "required": false,
                    "default": "50000000"
                },
                {
                    "name": "WEBMEET_TURN_UNAUTHORIZED_RPS",
                    "required": false,
                    "default": "10"
                },
                {
                    "name": "WEBMEET_TURN_MAX_ALLOCATION_LIFETIME_SECONDS",
                    "required": false,
                    "default": "3600"
                },
                {
                    "name": "WEBMEET_TURN_NONCE_LIFETIME_SECONDS",
                    "required": false,
                    "default": "600"
                },
                {
                    "name": "WEBMEET_LIVEKIT_PEER_HOST",
                    "required": false,
                    "default": "livekitserveragent"
                }
            ]
        },
        "dev": {
            "preinstall": "scripts/hooks/preinstall.sh",
            "openPorts": [
                "127.0.0.1:3478:3478/tcp",
                "127.0.0.1:3478:3478/udp",
                "127.0.0.1:20000-20127:20000-20127/udp"
            ],
            "env": [
                {
                    "name": "WEBMEET_TURN_AUTH_SECRET",
                    "required": false,
                    "sharedGeneratedSecret": true,
                    "runtime": false
                },
                {
                    "name": "WEBMEET_TURN_HOST",
                    "required": false,
                    "default": "127.0.0.1"
                },
                {
                    "name": "WEBMEET_TURN_USER_QUOTA",
                    "required": false,
                    "default": "4"
                },
                {
                    "name": "WEBMEET_TURN_TOTAL_QUOTA",
                    "required": false,
                    "default": "100"
                },
                {
                    "name": "WEBMEET_TURN_MAX_BPS",
                    "required": false,
                    "default": "2000000"
                },
                {
                    "name": "WEBMEET_TURN_BPS_CAPACITY",
                    "required": false,
                    "default": "50000000"
                },
                {
                    "name": "WEBMEET_TURN_UNAUTHORIZED_RPS",
                    "required": false,
                    "default": "10"
                },
                {
                    "name": "WEBMEET_TURN_MAX_ALLOCATION_LIFETIME_SECONDS",
                    "required": false,
                    "default": "3600"
                },
                {
                    "name": "WEBMEET_TURN_NONCE_LIFETIME_SECONDS",
                    "required": false,
                    "default": "600"
                },
                {
                    "name": "WEBMEET_LIVEKIT_PEER_HOST",
                    "required": false,
                    "default": "livekitserveragent"
                }
            ]
        },
        "prod": {
            "preinstall": "scripts/hooks/preinstall.sh",
            "openPorts": [
                "0.0.0.0:3478:3478/udp",
                "0.0.0.0:20000-20127:20000-20127/udp",
                "0.0.0.0:443:5349/tcp"
            ],
            "env": [
                {
                    "name": "WEBMEET_TURN_AUTH_SECRET",
                    "required": true,
                    "sharedGeneratedSecret": true,
                    "runtime": false
                },
                {
                    "name": "WEBMEET_TURN_HOST",
                    "required": false
                },
                {
                    "name": "WEBMEET_TURN_USER_QUOTA",
                    "required": false,
                    "default": "4"
                },
                {
                    "name": "WEBMEET_TURN_TOTAL_QUOTA",
                    "required": false,
                    "default": "100"
                },
                {
                    "name": "WEBMEET_TURN_MAX_BPS",
                    "required": false,
                    "default": "2000000"
                },
                {
                    "name": "WEBMEET_TURN_BPS_CAPACITY",
                    "required": false,
                    "default": "50000000"
                },
                {
                    "name": "WEBMEET_TURN_UNAUTHORIZED_RPS",
                    "required": false,
                    "default": "10"
                },
                {
                    "name": "WEBMEET_TURN_MAX_ALLOCATION_LIFETIME_SECONDS",
                    "required": false,
                    "default": "3600"
                },
                {
                    "name": "WEBMEET_TURN_NONCE_LIFETIME_SECONDS",
                    "required": false,
                    "default": "600"
                },
                {
                    "name": "WEBMEET_LIVEKIT_NODE_IP",
                    "required": false
                },
                {
                    "name": "WEBMEET_TURN_ALLOWED_PEER_IPS",
                    "required": false
                },
                {
                    "name": "WEBMEET_TURN_EXTERNAL_IP",
                    "required": false
                },
                {
                    "name": "WEBMEET_TURN_TLS_CERT_PATH",
                    "required": true,
                    "default": "/etc/turnserver/tls/fullchain.pem"
                },
                {
                    "name": "WEBMEET_TURN_TLS_KEY_PATH",
                    "required": true,
                    "default": "/etc/turnserver/tls/privkey.pem"
                }
            ]
        }
    }
}
